<ui:FluentWindow x:Class="SubtitlesFixer.App.SubtitleSearchWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Subtitrări Online — Subtitles Fixer"
                 Height="860"
                 Width="1100"
                 MinHeight="660"
                 MinWidth="820"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Subtitrări Online" />

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="24,14,24,24">
            <StackPanel MaxWidth="1200" HorizontalAlignment="Stretch">

                <!-- ═══ TITLU ════════════════════════════════════════════════ -->
                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"
                           Text="Caută subtitrări online" />
                <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,18"
                           Text="Gaseste subtitrari pentru fisierele care nu au inca .ro.srt. Aplic automat doar variantele in romana." />

                <!-- ═══ PANEL SETUP (vizibil cand nu exista cheie API) ═══════ -->
                <ui:Card x:Name="SetupCard"
                         Margin="0,0,0,16"
                         Padding="20">
                    <StackPanel>
                        <!-- Badge "Prima configurare" -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Background="#3978F6"
                                    CornerRadius="4"
                                    Padding="8,3">
                                <TextBlock Text="Prima configurare"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="White" />
                            </Border>
                        </StackPanel>

                        <TextBlock FontWeight="SemiBold"
                                   FontSize="14"
                                   Margin="0,0,0,4"
                                   Text="Configurează SubDL — gratuit, 2 minute" />
                        <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,20"
                                   Text="SubDL este un serviciu gratuit de subtitrari cu API public. Fiecare utilizator foloseste propria cheie personala (2000 cautari/zi, complet gratis)." />

                        <!-- Pas 1 -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Width="26" Height="26"
                                    CornerRadius="13"
                                    Background="#3978F6"
                                    VerticalAlignment="Top">
                                <TextBlock Text="1"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="12" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock FontWeight="SemiBold"
                                           Text="Creează un cont gratuit pe SubDL" />
                                <TextBlock TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,2,0,4"
                                           Text="E-mail + parola, fara card bancar." />
                                <TextBlock>
                                    <Hyperlink x:Name="RegisterLink"
                                               NavigateUri="https://subdl.com/register"
                                               RequestNavigate="Hyperlink_RequestNavigate">
                                        ➜  Deschide pagina de inregistrare subdl.com/register
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </Grid>

                        <!-- Pas 2 -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Width="26" Height="26"
                                    CornerRadius="13"
                                    Background="#3978F6"
                                    VerticalAlignment="Top">
                                <TextBlock Text="2"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="12" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock FontWeight="SemiBold"
                                           Text="Copiaza cheia ta API" />
                                <TextBlock TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,2,0,4"
                                           Text="Dupa logare, mergi la panoul tau de API si copiaza cheia afisata." />
                                <TextBlock>
                                    <Hyperlink x:Name="ApiPanelLink"
                                               NavigateUri="https://subdl.com/panel/api"
                                               RequestNavigate="Hyperlink_RequestNavigate">
                                        ➜  Deschide panoul API subdl.com/panel/api
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </Grid>

                        <!-- Pas 3 — input cheie -->
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Width="26" Height="26"
                                    CornerRadius="13"
                                    Background="#3978F6"
                                    VerticalAlignment="Top">
                                <TextBlock Text="3"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="12" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock FontWeight="SemiBold"
                                           Margin="0,0,0,6"
                                           Text="Introdu cheia API aici" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBox x:Name="ApiKeyInputBox"
                                               Grid.Column="0"
                                               Margin="0,0,8,0"
                                               VerticalContentAlignment="Center"
                                               PlaceholderText="Lipeste cheia ta SubDL aici..."
                                               FontFamily="Consolas"
                                               FontSize="12" />
                                    <ui:Button x:Name="ValidateKeyButton"
                                               Grid.Column="1"
                                               Margin="0,0,8,0"
                                               Appearance="Secondary"
                                               Content="Testeaza"
                                               Click="ValidateKeyButton_Click" />
                                    <ui:Button x:Name="SaveKeyButton"
                                               Grid.Column="2"
                                               Appearance="Primary"
                                               Content="Salveaza si continua"
                                               Click="SaveKeyButton_Click" />
                                </Grid>
                                <TextBlock x:Name="KeyValidationText"
                                           Margin="0,6,0,0"
                                           TextWrapping="Wrap"
                                           Visibility="Collapsed" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- ═══ STATUS CHEIE (vizibil cand cheia e configurata) ═══════ -->
                <ui:Card x:Name="KeyStatusCard"
                         Visibility="Collapsed"
                         Margin="0,0,0,12"
                         Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="✓  SubDL configurat"
                                       Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0" />
                            <TextBlock x:Name="KeyHintText"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       FontFamily="Consolas"
                                       FontSize="11" />
                        </StackPanel>
                        <ui:Button x:Name="ChangeKeyButton"
                                   Grid.Column="1"
                                   Appearance="Secondary"
                                   Content="Schimba cheia"
                                   Click="ChangeKeyButton_Click" />
                    </Grid>
                </ui:Card>

                <!-- ═══ CONFIGURARE CAUTARE ══════════════════════════════════ -->
                <ui:Card x:Name="SearchConfigCard"
                         Visibility="Collapsed"
                         Margin="0,0,0,14"
                         Padding="18">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold"
                                   Margin="0,0,0,10"
                                   Text="Folder si preferinte" />

                        <!-- Folder picker -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox x:Name="FolderPathBox"
                                        Grid.Column="0"
                                        Margin="0,0,10,0"
                                        VerticalContentAlignment="Center"
                                        PlaceholderText="Selecteaza folderul cu fisiere video..." />
                            <ui:Button x:Name="BrowseButton"
                                       Grid.Column="1"
                                       Appearance="Secondary"
                                       Content="Rasfoieste..."
                                       Click="BrowseButton_Click" />
                        </Grid>

                        <!-- Optiune subfolders -->
                        <CheckBox x:Name="RecurseCheckBox"
                                  IsChecked="True"
                                  Margin="0,0,0,12"
                                  Content="Scaneaza si subfolderele" />

                        <!-- Limbi -->
                        <TextBlock FontWeight="SemiBold"
                                   Margin="0,0,0,8"
                                   Text="Limbi de cautat (in ordine de prioritate)" />
                        <WrapPanel Margin="0,0,0,4">
                            <CheckBox x:Name="LangRoCheckBox"
                                      IsChecked="True"
                                      Margin="0,0,20,6"
                                      Content="🇷🇴  Română  (prioritar)" />
                            <CheckBox x:Name="LangEnCheckBox"
                                      IsChecked="True"
                                      Margin="0,0,20,6"
                                      Content="🇬🇧  Engleză  (fallback)" />
                        </WrapPanel>
                        <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="11.5"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,0"
                                   Text="Engleza este folosita doar la cautare si comparatie. Aplicatia nu o salveaza automat ca .ro.srt." />
                    </StackPanel>
                </ui:Card>

                <!-- ═══ BUTOANE ACTIUNE ═══════════════════════════════════════ -->
                <WrapPanel x:Name="ActionPanel"
                           Visibility="Collapsed"
                           Margin="0,0,0,8"
                           VerticalAlignment="Center">
                    <ui:Button x:Name="ScanButton"
                               Margin="0,0,10,10"
                               Appearance="Secondary"
                               Content="Scaneaza folderul"
                               Click="ScanButton_Click" />
                    <ui:Button x:Name="SearchAllButton"
                               Margin="0,0,10,10"
                               Appearance="Secondary"
                               IsEnabled="False"
                               Content="Cauta toate subtitrarile"
                               Click="SearchAllButton_Click" />
                    <ui:Button x:Name="DownloadAllButton"
                               Margin="0,0,20,10"
                               Appearance="Primary"
                               IsEnabled="False"
                               Content="Salveaza toate subtitrarile"
                               Click="DownloadAllButton_Click" />
                    <TextBlock x:Name="ActionStatusText"
                               Margin="0,2,0,10"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="" />
                </WrapPanel>

                <!-- Progress bar -->
                <ProgressBar x:Name="OperationProgressBar"
                             Margin="0,-2,0,14"
                             Height="4"
                             Minimum="0"
                             Maximum="100"
                             Value="0"
                             Visibility="Collapsed" />

                <!-- ═══ LISTA REZULTATE ══════════════════════════════════════ -->
                <Border x:Name="ResultsBorder"
                        Visibility="Collapsed"
                        Padding="12"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel x:Name="ResultsPanel" />
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
